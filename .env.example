# Optional MapLibre style URL. Leave unset to use the OpenFreeMap Liberty
# vector style with OSM-derived 3D building extrusions.
# Set to "osm-raster" to force the OpenStreetMap raster fallback.
NEXT_PUBLIC_MAP_STYLE_URL=

# Optional building extrusion config. Defaults match OpenFreeMap Liberty:
# source=openmaptiles, source-layer=building, min zoom=13.
NEXT_PUBLIC_MAP_BUILDING_SOURCE=
NEXT_PUBLIC_MAP_BUILDING_SOURCE_LAYER=building
NEXT_PUBLIC_MAP_BUILDING_MIN_ZOOM=13

# Canonical production origin used for Open Graph, X cards, and share URLs.
NEXT_PUBLIC_SITE_URL=https://rewindcup.com

# Optional manual Cloudflare Web Analytics site token. This token is public and
# should only be set when dashboard automatic injection is disabled.
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
